	<FactionOff2>0x0</FactionOff2>
	<!-- Typically 0 (read the value directly) -->
	<FactionBase>0x00A47DCC</FactionBase>
	<!-- FactionTemplate.dbc row array base pointer -->

	<!-- Class / Race from base struct (pointer chain via unit vtable data) -->
	<ClassPtrOffset>0x0</ClassPtrOffset>
	<!-- Disabled: use UNIT_FIELD_BYTES_0 descriptor instead -->
	<ClassIdOffset>0x0</ClassIdOffset>
	<RaceIdOffset>0x0</RaceIdOffset>

	<!-- TLS path (disabled — we use static addresses instead) -->
	<TLSSlot>0x0</TLSSlot>
	<TLSPlayerID>0x0</TLSPlayerID>
	<TLSMainTable>0x0</TLSMainTable>

	<!-- Structure peek offsets (legacy) -->
	<VAPeek>0x10</VAPeek>
	<FLPeek>0x14</FLPeek>

