	<!-- ================================================================== -->
	<!-- Aura / Buff system offsets (new-style buffs)                        -->
	<!-- Offsets from unit BaseAddress for the 3.3.5a aura system            -->
	<!-- ================================================================== -->
	<NB_BaseCount>0xDD0</NB_BaseCount>
	<!-- Aura count: [BaseAddress + 0xDD0] -->
	<NB_BaseList>0xC50</NB_BaseList>
	<!-- Aura array start: BaseAddress + 0xC50 -->
	<NB_ExtCount>0xDD4</NB_ExtCount>
	<!-- Extended aura count (when > base capacity) -->
	<NB_ExtListPtr>0xC54</NB_ExtListPtr>
	<!-- Extended aura list pointer -->
	<UNIT_FIELD_AURA>0x148</UNIT_FIELD_AURA>
	<!-- Legacy aura descriptor offset for old buff reading -->

	<!-- ================================================================== -->
	<!-- Faction evaluation (pointer chain for GetReaction)                  -->
	<!-- ================================================================== -->
	<FactionSub>0x00A47DD8</FactionSub>
