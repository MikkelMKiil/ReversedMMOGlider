<?xml version="1.0" encoding="utf-8"?>
<Offsets>
	<!-- ================================================================== -->
	<!-- WoW 3.3.5a Build 12340 — Static Memory Addresses & Base Offsets    -->
	<!-- All values verified against community-documented offsets            -->
	<!-- ================================================================== -->

	<!-- Object Manager pointer chain -->
	<MainTable>0x00C79CE0</MainTable>
	<!-- ClientConnection static pointer -->
	<MainTableProbe>0x2ED0</MainTableProbe>
	<!-- CurMgr offset: [ClientConnection + 0x2ED0] = ObjectManager -->
	<InitialOffset>0xAC</InitialOffset>
	<!-- FirstObject offset in ObjectManager -->
	<MainTableLocalGuid>0xC0</MainTableLocalGuid>
	<!-- Local player GUID offset inside ObjectManager -->
	<MainTableActivePlayer>0x18</MainTableActivePlayer>
	<!-- Not used for active player lookup in 3.3.5a; kept for compat -->
	<GameObjNext>0x3C</GameObjNext>
	<!-- Object linked-list traversal: next object pointer offset from base struct -->

	<!-- Static GUID addresses -->
	<PlayerIdAddr>0x00CA1238</PlayerIdAddr>
	<!-- Static address for local player GUID (3.3.5a/12340) -->
	<TargetId>0x00BD07B0</TargetId>
	<!-- Current target GUID -->
	<UnderCursor>0x00BD07A0</UnderCursor>
	<!-- MouseOver GUID -->

	<!-- Descriptor table type names (used by OffsetManager constructor) -->
	<!-- These are NOT memory addresses; they're identifiers for the static descriptor tables -->
	<D_Player>0x0</D_Player>
	<D_Items>0x0</D_Items>
	<D_NPC>0x0</D_NPC>
	<D_Object>0x0</D_Object>
	<D_Container>0x0</D_Container>

	<!-- ================================================================== -->
	<!-- Unit base struct offsets (from BaseAddress, NOT descriptor)          -->
	<!-- These are offsets into the C++ CGUnit_C object struct               -->
	<!-- ================================================================== -->
	<X>0x798</X>
	<Y>0x79C</Y>
	<Z>0x7A0</Z>
	<Heading>0x7A8</Heading>
	<Pitch>0x7AC</Pitch>

	<!-- Movement flags / structs -->
	<MoveFlags>0xD8</MoveFlags>
	<!-- MovementInfo offset from unit base (try 0xD8 or 0xC8 for 3.3.5a) -->
	<MoveStruct2>0x0</MoveStruct2>
	<!-- Disabled — movement flags read directly now -->
	<MoveFlags2>0x0</MoveFlags2>

	<!-- Unit name resolution -->
	<MonsterDefinition>0x964</MonsterDefinition>
	<!-- UnitNameCachePointer: [BaseAddress + 0x964] → name cache struct -->
	<UnitNameSecond>0x0</UnitNameSecond>
	<!-- Additional offset inside name cache for name pointer (0 = read directly) -->
	<UnitTitle>0x4</UnitTitle>
	<!-- Offset for title string pointer inside name cache -->
	<CreatureType>0x10</CreatureType>
	<!-- Creature type offset inside UnitNameCache -->
	<HarvestType>0x14</HarvestType>
	<!-- Harvest flags offset inside UnitNameCache -->

	<!-- GameObject name resolution -->
	<NodeName>0x1A4</NodeName>
	<!-- [BaseAddress + 0x1A4] → GO name struct pointer -->
	<NodeNameSecond>0x90</NodeNameSecond>
	<!-- Offset inside name struct to actual name string pointer (try 0x8) -->

	<!-- ================================================================== -->
	<!-- Static Global Addresses                                             -->
	<!-- ================================================================== -->

	<!-- Casting -->
	<PlayerCasting>0x00CECAAC</PlayerCasting>
